generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

generator json {
  provider = "prisma-json-types-generator"
}

enum UserRole {
  user
  admin
}

enum OAuthProvider {
    google
    naver
    kakao
    apple
}

enum FriendshipStatus {
    pending
    accepted
    declined
    removed
}

model User {
  id           String   @id @default(uuid(7)) @db.Uuid
  email        String   @unique
  nickname     String   @unique
  passwordHash String?
  role         UserRole @default(user)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
  bio          String?
  lastActiveAt DateTime? @db.Timestamptz(3)
  image String?

  recommendations Recommendation[]
  reactions      Reaction[]
  savedCards SavedCard[]
  comments Comment[]
  oauthAccounts OAuthAccount[]

  sentFriendRequests Friendship[] @relation("FriendshipRequester")
  receivedFriendRequests Friendship[] @relation("FriendshipAddressee")
  blocksOutgoing         Block[]      @relation("BlockBlocker")
  blocksIncoming         Block[]      @relation("BlockBlocked")
}


model OAuthAccount {
    id String @id @default(uuid(7)) @db.Uuid
    provider OAuthProvider
    providerAccountId String
    userId String @db.Uuid
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now()) @db.Timestamptz(3)

    @@unique([provider,providerAccountId])
    @@index([provider])
}

model Recommendation {
  id        String   @id @default(uuid(7)) @db.Uuid
  title     String
  artist    String
  embedUrl  String
  reason    String
  moods     String[]
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  authorId  String   @db.Uuid
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  savedCards SavedCard[]
  reactions Reaction[]
  comments Comment[]

  @@index([authorId])
}

model Reaction {
  id               String   @id @default(uuid(7)) @db.Uuid
  recommendationId String   @db.Uuid
  type             String   @default("like")
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
  @@index([recommendationId])
  @@index([userId])
}

model SavedCard{
  id String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid
  recommendationId String @db.Uuid
  customization Json /// [SavedCardCustomization]
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendationId])
  @@index([userId])
}

model Comment {
    id String @id @default(uuid(7)) @db.Uuid
    recommendationId String @db.Uuid
    authorId String @db.Uuid
    body String
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    updatedAt DateTime @updatedAt @db.Timestamptz(3)

    recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
    author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

    @@index([recommendationId])
    @@index([authorId])
}

model Friendship {
    id String @id @default(uuid(7)) @db.Uuid
    requesterId String @db.Uuid
    addresseeId String @db.Uuid
    status FriendshipStatus @default(pending)
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    respondedAt DateTime? @db.Timestamptz(3)

    requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
    addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

    @@unique([requesterId, addresseeId])
    @@index([requesterId,status])
    @@index([addresseeId,status])
}

model Block {
    id String @id @default(uuid(7)) @db.Uuid
    blockerId String @db.Uuid
    blockedId String @db.Uuid
    createdAt DateTime @default(now()) @db.Timestamptz(3)

    blocker User @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
    blocked User @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

    @@unique([blockerId, blockedId])
    @@index([blockedId])
}