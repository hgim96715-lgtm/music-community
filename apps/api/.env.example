# 백엔드 포트
PORT=3030

# 프론트엔드 URL (CORS) — origin만. 경로(/recommendations 등) 붙이지 않음
FRONTEND_URL=http://localhost:3031

# PostgreSQL (로컬 Docker — Mac 기본 5432와 충돌 방지로 호스트 5433)
DATABASE_URL=postgresql://music_user:music_password@localhost:5433/music_community_db?schema=public&sslmode=disable
POSTGRES_USER=music_user
POSTGRES_PASSWORD=music_password
POSTGRES_DB=music_community_db
POSTGRES_PORT=5433

API_JWT_SECRET=

# OAuth — express-session (state · oauthNext)
SESSION_SECRET=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3030/auth/oauth/google/callback

# Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:3030/auth/oauth/naver/callback

# Kakao (실사용은 비즈 앱 + account_email 필요 — Nest 라우트는 유지)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3030/auth/oauth/kakao/callback
